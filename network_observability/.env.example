# Network observability - copy to .env and set values as needed.
# Auth applies ONLY to:
# 1) otel-collector -> otel-collector-network
# 2) otel-collector -> global-reciver
#
# Everything else runs without auth.

# --- Global auth toggle ---
# false = no auth mode
# true  = auth mode on both protected paths
NETWORK_EXPORT_AUTH_ENABLED=false

# When auth is enabled, protected endpoints must be https://
NETWORK_EXPORT_REQUIRE_HTTPS=false

# --- Sender exporter endpoints (protected paths) ---
# In no-auth mode (default), these can be local http:// endpoints.
# In auth mode, set both to https:// endpoints.
RECEIVER_OTLP_ENDPOINT=http://global-reciver:6060
COLLECTOR_NETWORK_ENDPOINT=http://otel-collector-network:4318

# Optional CA files for TLS verification when using HTTPS endpoints.
RECEIVER_CA_FILE=
COLLECTOR_NETWORK_CA_FILE=

# --- Dynamic token fetch from auth service (sender, auth mode) ---
# OAuth2 token endpoint and client credentials used by otel-collector config.auth.yaml
AUTH_TOKEN_URL=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# --- OIDC validation at otel-collector-network (auth mode) ---
# otel-collector-network validates JWT/OIDC directly on its OTLP receiver.
OIDC_ISSUER_URL=
OIDC_AUDIENCE=

# --- Non-protected/no-auth paths ---
JAEGER_ENDPOINT=jaeger:4317
ZIPKIN_ENDPOINT=http://zipkin:9411
LOKI_ENDPOINT=http://loki:3100

# --- Adapter ---
# keep true for local plaintext adapter->collector, set false in hardened deployments
OTEL_EXPORTER_OTLP_INSECURE=true
